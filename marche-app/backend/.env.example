# Base de données
DATABASE_URL="postgresql://postgres:passer@localhost:5432/marche_db"

# JWT
JWT_SECRET="marche-secret-key-change-in-production"

# OTP (stub pour le développement)
OTP_DEFAULT_CODE=123456

# Admin par défaut (créé par le seeder)
ADMIN_PHONE=810000000
ADMIN_COUNTRY_CODE=+221
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=MARCHÉ
ADMIN_EMAIL=admin@marche.cd

# App
PORT=5000
CURRENCY=FCFA

# CORS
CORS_ORIGIN=*
# CORS_ORIGIN=https://marchee-app.com

# Rate limiting (requêtes max par IP par fenêtre de 15 min)
RATE_LIMIT_MAX=200

# Swagger
ENABLE_SWAGGER=true
